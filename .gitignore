# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Whisper model caches (downloaded on first use, never committed)
.whisper_cache/
models/

# razbiram-nlp gloss cache (local LLM gloss results; runtime data, never committed)
.razbiram_cache/

# Node / Vite viewer (M5)
viewer/node_modules/
viewer/dist/
viewer/.vite/

# Local audio the user brings — BYO-audio is never committed (Briefing §8)
*.mp3
*.wav
*.m4a
*.ogg
*.flac
# ...except explicitly CC-licensed / own example assets tracked under examples/
!examples/sample-audio/**

# Local, throwaway demo assets (TTS audio + its .listen.json) — never committed;
# the shipped example is an own recording under examples/sample-audio/ (M7).
examples/_demo/

# Env / secrets (ECOSYSTEM §7 — secrets only via env, never in the repo)
.env
.env.local

# Local Claude Code settings (machine-specific); skills under .claude/skills/ ARE tracked
.claude/settings.local.json

# OS
.DS_Store

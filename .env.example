# razbiram-listen — environment template (ECOSYSTEM §7: secrets via env only).
# Copy to `.env` (git-ignored) and fill in as needed. Everything runs local-first
# by default; no key is required for the offline path.

# Optional gloss provider. Default is local Ollama (no key). The Anthropic
# provider is optional and must be explicitly chosen; the key lives only here.
# ANTHROPIC_API_KEY=

# Ollama endpoint, if not the default.
# OLLAMA_HOST=http://localhost:11434

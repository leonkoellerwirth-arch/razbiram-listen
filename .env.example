# razbiram-listen — environment template (ECOSYSTEM §7: secrets via env only).
# Copy to `.env` (git-ignored) and fill in as needed. Everything runs local-first
# by default; no key is required for the offline path.

# Optional gloss provider. Default is local Ollama (no key). The Anthropic
# provider is optional and must be explicitly chosen; the key lives only here.
# ANTHROPIC_API_KEY=

# Ollama endpoint, if not the default.
# OLLAMA_HOST=http://localhost:11434

# Difficulty/vocab stages (document + per-word CEFR bands) read the hub's data and
# config files, which the installed wheel does not ship. Point these at a
# razbiram-nlp checkout for full-quality CEFR; without them those stages are
# skipped and you still get sentence-level translations.
# RAZBIRAM_NLP_DATA_DIR=/path/to/razbiram-nlp/data
# RAZBIRAM_NLP_CONFIG_DIR=/path/to/razbiram-nlp/config
